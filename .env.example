# ─────────────────────────────────────────────────────────────────
# W'xOps IDP — environment configuration
# Copy this file to .env.local and fill in your real values
# ─────────────────────────────────────────────────────────────────

# ── Giscus (GitHub Discussions) ─────────────────────────────────
# Get all values from https://giscus.app by entering your repo URL
NEXT_PUBLIC_GISCUS_REPO=owner/wxops.cloud
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx

# ── GitHub repo (for issue template links) ───────────────────────
NEXT_PUBLIC_GITHUB_REPO=owner/wxops.cloud

# ── GitHub Activity Dashboard ────────────────────────────────────
# Optional — a fine-grained PAT with only "Discussions: Read" on
# this repo. Without it, the dashboard still works but is limited
# to 60 unauthenticated requests/hour by GitHub.
# NEXT_PUBLIC_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# ── Deployment ───────────────────────────────────────────────────
# If deploying to a GitHub Pages sub-path, set this.
# Example: /wxops.cloud   (leave empty for root domain)
# NEXT_PUBLIC_BASE_PATH=/wxops.cloud
